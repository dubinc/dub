    },
    {
      "path": "/api/cron/trigger-withdrawal",
      "schedule": "0 0,12 * * *"
    },
    {
      "path": "/api/cron/trigger-backup",
      "schedule": "40 0,8,12,20 * * *"
    },
    {
      "path": "/api/cron/payouts/force-withdrawals",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/api/cron/payouts/reminders/partners",
      "schedule": "0 14 * * *"
    },
    {
      "path": "/api/cron/payouts/reminders/program-owners",
      "schedule": "0 13 25-31,1-5 * *"
    },
    {
      "path": "/api/cron/bounties/queue-sync-social-metrics",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/sitemaps/queue",
      "schedule": "0 2 * * *"
    }
  ],
  "functions": {
    "app/(ee)/api/cron/**/*.ts": {
      "maxDuration": 600
    }
  }
