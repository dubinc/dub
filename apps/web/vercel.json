{
  "crons": [
    {
      "path": "/api/cron/domains/verify",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/email-domains/verify",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/domains/renewal-reminders",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/domains/renewal-payments",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/streams/update-workspace-clicks",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/streams/update-workspace-links-usage",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/streams/update-partner-stats",
      "schedule": "*/2 * * * *"
    },
    {
      "path": "/api/cron/partner-program-summary",
      "schedule": "0 13 1 * *"
    },
    {
      "path": "/api/cron/pending-applications-summary",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/trial-emails",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/payouts/aggregate-due-commissions",
