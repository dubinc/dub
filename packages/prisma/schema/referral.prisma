enum ReferralStatus {
  pending
  qualified
  meeting
  negotiation
  unqualified
  closedWon
  closedLost
}

model PartnerReferral {
  id         String         @id @default(cuid())
  programId  String
  partnerId  String
  customerId String?
  name       String
  email      String
  company    String
  formData   Json?          @db.Json
  status     ReferralStatus @default(pending)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  @@index([programId, partnerId])
  @@index(partnerId)
  @@index(customerId)
  @@fulltext([email, name])
}